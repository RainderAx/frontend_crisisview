pipeline {
    agent any 

    stages {
        stage('Deploy Staging') {
            steps {
                script {
                    
                    sh "docker compose pull"
                    

                    sh "docker compose up -d --remove-orphans frontend-crisisview"
                }
            }
        }
    }
    
    post {
        success {
            echo "Déploiement réussi sur l'environnement de Staging."
        }
    }
}